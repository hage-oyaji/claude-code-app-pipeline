{
  "permissions": {
    "allow": [
      "Bash(node *)",
      "Bash(java *)",
      "Bash(gradle *)",
      "Bash(tasklist)",
      "Read(//c/Program Files//**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/update-pipeline-status.js\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/update-pipeline-status.js\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
