{
  "permissions": {
    "allow": [
      "Bash(node *)",
      "Bash(java *)",
      "Bash(gradle *)",
      "Bash(tasklist)",
      "Read(//c/Program Files//**)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log)",
      "Bash(git log *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/update-pipeline-status.js\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/update-pipeline-status.js\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
